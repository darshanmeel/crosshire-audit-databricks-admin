# sqlfluff config (OPTIONAL / advisory CI check).
# The authoritative gate is tools/lint_headers.py; sqlfluff only sanity-parses the SQL.
# Named parameter markers (:period_days, thresholds) are resolved by the placeholder templater.
[sqlfluff]
dialect = databricks
templater = placeholder
max_line_length = 0

[sqlfluff:templater:placeholder]
param_style = colon
crit_admin_events = 100
crit_avg_file_mb = 8
crit_blast_principals = 50
crit_churn_events = 5
crit_churn_per_hour = 10
crit_clustering_dbu = 200
crit_coverage_pct = 20
crit_dead_days = 365
crit_denial_count = 50
crit_endpoint_usd_per_day = 250
crit_failed_count = 20
crit_failed_logins = 20
crit_failed_run_rows = 20
crit_failed_runs = 10
crit_failed_updates = 10
crit_idle_dbus = 500
crit_idle_hours = 24
crit_idle_ratio = 0.8
crit_io_cache_pct = 20
crit_job_dbus_per_day = 200
crit_maint_dbu = 100
crit_min_idle_instances = 20
crit_near_timeout_runs = 10
crit_never_started = 10
crit_no_timeout_jobs = 20
crit_no_timeout_tasks = 20
crit_noop_dbu = 20
crit_notebook_dbus_per_day = 50
crit_orphan_jobs = 20
crit_pii_gap_events = 50
crit_pipeline_dbus = 2000
crit_prune_ratio = 0.2
crit_queue_p95_s = 300
crit_queue_secs = 600
crit_reach_principals = 50
crit_realization_ratio = 0.9
crit_resource_dbus_per_day = 200
crit_runas_events = 25
crit_scan_gb = 500
crit_setup_p95_s = 300
crit_share_usd = 100
crit_shuffle_gb = 200
crit_spill_gb = 10
crit_stale_days = 14
crit_succeeded_with_failed = 10
crit_total_hours = 5
crit_total_retries = 20
crit_wasted_dbus = 50
crit_wh_share = 0.25
idle_cpu_pct = 5
min_observed_hours = 1
min_slices = 60
near_timeout_ratio = 0.8
oversized_cpu_pct = 20
oversized_mem_pct = 30
period_days = 30
stale_days = 30
top_n = 200
warn_admin_events = 20
warn_avg_file_mb = 32
warn_blast_principals = 10
warn_churn_events = 2
warn_churn_per_hour = 4
warn_clustering_dbu = 50
warn_coverage_pct = 50
warn_dead_days = 90
warn_denial_count = 10
warn_endpoint_usd_per_day = 50
warn_failed_count = 5
warn_failed_logins = 5
warn_failed_run_rows = 5
warn_failed_runs = 3
warn_failed_updates = 3
warn_idle_dbus = 100
warn_idle_hours = 4
warn_idle_ratio = 0.5
warn_io_cache_pct = 50
warn_job_dbus_per_day = 50
warn_low_requests = 10
warn_maint_dbu = 20
warn_min_idle_instances = 5
warn_near_timeout_runs = 3
warn_never_started = 3
warn_no_timeout_jobs = 5
warn_no_timeout_tasks = 5
warn_noop_dbu = 5
warn_notebook_dbus_per_day = 10
warn_orphan_jobs = 5
warn_pii_gap_events = 5
warn_pipeline_dbus = 500
warn_prune_ratio = 0.5
warn_queue_p95_s = 60
warn_queue_secs = 60
warn_reach_principals = 10
warn_realization_ratio = 0.75
warn_resource_dbus_per_day = 50
